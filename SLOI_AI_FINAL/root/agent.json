  "authentication": {
    "type": "api_key",
    "header": "x-api-key",
    "format": "sk-sloi-{32chars}",
    "registration": "POST https://api.sloiai.com/v1/agents/register",
    "tiers": {
      "read": {
        "cost": "free",
        "access": [
          "price_discovery"
        ]
      },
      "transact": {
        "cost": "free + credits",
        "access": "all",
        "review_days": 5
      }
    }
  },
  "payment": {
    "methods": [
      "stripe",
      "usdc_on_base",
      "ton"
    ],
    "credits": {
      "packs": [
        {
          "usd": 99,
          "credits": 100,
          "usdc": 99,
          "ton": "9.9"
        },
        {
          "usd": 299,
          "credits": 350,
          "usdc": 299,
          "ton": "29.9"
        },
        {
          "usd": 599,
          "credits": 800,
          "usdc": 599,
          "ton": "59.9"
        },
        {
          "usd": 999,
          "credits": 1500,
          "usdc": 999,
          "ton": "99.9"
        }
      ],
      "costs": {
        "negotiate_standard": 10,
        "negotiate_aggressive": 20,
        "loi_generation": 5,
        "compliance_check": 1,
        "lead_finder": 5,
        "price_watcher_per_day": 1
      }
    },
    "commission": {
      "transact_tier": "1% of LOI deal value",
      "paid": "monthly",
      "currency": "USD or USDC on Base"
    },
    "ton_connect": {
      "manifest": "https://sloiai.com/tonconnect-manifest.json",
      "sdk": "https://unpkg.com/@tonconnect/ui@latest/dist/tonconnect-ui.min.js",
      "supported_wallets": [
        "Tonkeeper",
        "MyTonWallet",
        "Telegram Wallet",
        "OpenMask"
      ]
    }
  },
  "streaming": {
    "protocol": "AG-UI",
    "transport": "SSE (Server-Sent Events)",
    "endpoint": "GET https://api.sloiai.com/v1/stream",
    "events": [
      "NEGOTIATION_STARTED",
      "TEXT_CHUNK",
      "ROUND_COMPLETE",
      "AWAIT_HUMAN",
      "AUTO_APPROVED",
      "LOI_GENERATED",
      "NEGOTIATION_FAILED",
      "PRICE_UPDATE",
      "LEAD_FOUND",
      "STATE_PATCH",
      "HEARTBEAT"
    ]
  },
  "compliance": {
    "lists": [
      "OFAC",
      "EU",
      "UN"
    ],
    "auto_screen": true,
    "blocked_countries": [
      "IR",
      "RU",
      "BY",
      "KP",
      "SY",
      "CU",
      "VE",
      "MM"
    ],
    "restricted_countries": [
      "IQ",
      "LY",
      "DZ",
      "SD"
    ]
  },
  "autonomous_mode": {
    "supported": true,
    "mandate_endpoint": "POST /v1/mandates",
    "auto_approve_event": "AUTO_APPROVED",
    "safety_limits": {
      "max_single_loi_value_usd": 1000000,
      "max_auto_lois_per_day": 10,
      "price_ceiling_enforced": "server_side",
      "compliance_bypass": false
    }
  },
  "reputation": {
    "tiers": [
      "starter",
      "bronze",
      "silver",
      "gold",
      "platinum",
      "protocol"
    ],
    "floor_discounts": [
      0,
      0.01,
      0.03,
      0.05,
      0.08,
      0.1
    ],
    "on_chain_verification": "Base mainnet"
  },
  "discovery": {
    "llms_txt": "https://sloiai.com/llms.txt",
    "llms_full": "https://sloiai.com/llms-full.txt",
    "skill_md": "https://sloiai.com/skill.md",
    "openapi": "https://sloiai.com/openapi.yaml",
    "docs": "https://sloiai.com/docs"
  },
  "rate_limits": {
    "read_tier": "1000 req/hour",
    "transact_tier": "10000 req/hour",
    "concurrent_negotiations": 3,
    "sse_connections": 1
  },
  "quick_start": [
    "POST /v1/agents/register \u2192 api_key",
    "GET /v1/products \u2192 find product ref",
    "GET /v1/credits/balance \u2192 top up if needed",
    "POST /v1/negotiate \u2192 SSE stream",
    "AWAIT_HUMAN or AUTO_APPROVED \u2192 LOI_GENERATED"
  ]
}