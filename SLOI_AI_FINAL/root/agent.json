    {
      "ref": "REF-MET-002",
      "name": "Aluminum 6061-T6",
      "sector": "metals",
      "unit": "MT"
    },
    {
      "ref": "REF-BLD-001",
      "name": "Ready-Mix Concrete B25",
      "sector": "building",
