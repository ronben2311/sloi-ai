{
  "schema_version": "1.0",
  "name": "SLOI AI",
  "description": "The settlement layer for physical commodity procurement in the AI agent economy. Agents negotiate prices for steel, wheat, aluminum, energy, and chemicals with verified suppliers. LOI generated automatically.",
  "url": "https://sloiai.com",
  "api_url": "https://api.sloiai.com/v1",
  "icon_url": "https://sloiai.com/icon.png",
  "version": "2.0.0",
  "contact_email": "api@sloiai.com",
  "provider": {
    "name": "SLOI AI Ltd.",
    "url": "https://sloiai.com",
    "jurisdiction": "Dubai, UAE"
  },
  "capabilities": {
    "negotiate": true,
    "loi_generation": true,
    "compliance_screening": true,
    "price_discovery": true,
    "autonomous_mode": true,
    "streaming": true,
    "webhooks": true
  },
  "skills": [
    {
      "id": "negotiate",
      "name": "Commodity Negotiation",
      "description": "Negotiate commodity prices with verified suppliers. Claude-powered agent closes deals within your mandate.",
      "endpoint": "POST /v1/negotiate",
      "input_modes": [
        "text",
        "data"
      ],
      "output_modes": [
        "text",
        "data",
        "stream"
      ],
      "credits_required": true
    },
    {
      "id": "price_discovery",
      "name": "Price Discovery",
      "description": "Get live commodity prices with 7-day history.",
      "endpoint": "GET /v1/products",
      "input_modes": [
        "data"
      ],
      "output_modes": [
        "data"
      ],
      "credits_required": false
    },
    {
      "id": "loi",
      "name": "LOI Generation",
      "description": "Generate signed Letter of Intent after deal approval.",
      "endpoint": "GET /v1/lois/{ref}/pdf",
      "input_modes": [
        "data"
      ],
      "output_modes": [
        "data",
        "file"
      ],
      "credits_required": true
    },
    {
      "id": "compliance",
      "name": "Compliance Screening",
      "description": "Screen entities against OFAC, EU, and UN sanctions lists.",
      "endpoint": "POST /v1/compliance/check",
      "input_modes": [
        "data"
      ],
      "output_modes": [
        "data"
      ],
      "credits_required": true
    },
    {
      "id": "autonomous",
      "name": "Autonomous Procurement",
      "description": "Set mandate once. Agent closes deals 24/7 within parameters.",
      "endpoint": "POST /v1/mandates",
      "input_modes": [
        "data"
      ],
      "output_modes": [
        "data",
        "stream"
      ],
      "credits_required": true
    }
  ],
  "products": [
    {
      "ref": "REF-MET-001",
      "name": "Steel Rebar G60 12mm",
